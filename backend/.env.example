# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=metrics
KAFKA_GROUP_ID=nexus-ingestor

# TimescaleDB
DATABASE_URL=postgres://nexus:nexus_secret@localhost:5432/nexus?sslmode=disable
DB_MAX_OPEN=25
DB_MAX_IDLE=25
DB_MAX_LIFETIME=5m

# Batch flusher
BATCH_SIZE=1000
BATCH_FLUSH_INTERVAL=500ms

# API server
API_PORT=8080
API_QUERY_TIMEOUT=2s
API_READ_TIMEOUT=10s
API_WRITE_TIMEOUT=10s

# WebSocket
WS_THROTTLE_INTERVAL=250ms

# Logging
LOG_LEVEL=info
